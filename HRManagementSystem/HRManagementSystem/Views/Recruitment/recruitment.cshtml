@{
    ViewData["Title"] = "Recruitment";
}
<div class="app">
      <aside class="sidebar" id="sidebar"></aside>

      <div class="main">
        <header class="topbar" id="topbar"></header>

        <div class="content">
            <div class="subnav-wrap">
              <nav class="nav custom-nav-tabs">
                <a class="nav-link active-tab" href="recruitment.html">Overview</a>
                <a class="nav-link" href="requisitions.html">Requisitions</a>
                <a class="nav-link" href="applications.html">Applications</a>
                <a class="nav-link" href="interviews.html">Interviews</a>
                <a class="nav-link" href="hiring-decision.html">Hiring Decisions</a>
              </nav>
            </div>

            <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
                <div>
                    <h1 style="font-size:24px; font-weight:700; color:var(--text)">Recruitment Overview</h1>
                    <p class="panel-sub mb-0">Manage candidates and hiring pipeline</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1">
                        <span class="material-symbols-outlined" style="font-size:16px">filter_list</span> Filter
                    </button>
                    <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1">
                        <span class="material-symbols-outlined" style="font-size:16px">calendar_month</span> This Month
                    </button>
                    <button class="btn btn-primary btn-sm d-flex align-items-center gap-1">
                        <span class="material-symbols-outlined" style="font-size:16px">add</span> Post New Job
                    </button>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="kpi-head">
                            <span class="kpi-label">Open Positions</span>
                            <span class="material-symbols-outlined kpi-icon icon-primary">work</span>
                        </div>
                        <div class="kpi-value" style="font-size:22px">24</div>
                        <div class="kpi-foot text-success">
                            <span class="material-symbols-outlined" style="font-size:14px">trending_up</span> +3 this week
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="kpi-head">
                            <span class="kpi-label">Total Candidates</span>
                            <span class="material-symbols-outlined kpi-icon icon-tertiary">person_search</span>
                        </div>
                        <div class="kpi-value" style="font-size:22px">1,284</div>
                        <div class="kpi-foot text-success">
                            <span class="material-symbols-outlined" style="font-size:14px">trending_up</span> +12% growth
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="kpi-head">
                            <span class="kpi-label">Interviews</span>
                            <span class="material-symbols-outlined kpi-icon" style="background:rgba(87,95,103,.1); color:var(--secondary)">event</span>
                        </div>
                        <div class="kpi-value" style="font-size:22px">42</div>
                        <div class="kpi-foot text-muted">8 for today</div>
                    </div>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <div class="kpi-card">
                        <div class="kpi-head">
                            <span class="kpi-label">Pending Offers</span>
                            <span class="material-symbols-outlined kpi-icon icon-danger">check_circle</span>
                        </div>
                        <div class="kpi-value" style="font-size:22px">18</div>
                        <div class="kpi-foot text-danger">3 expiring soon</div>
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12 col-xl-4">
                    <div class="d-flex flex-column gap-3">
                        <div class="panel">
                            <div class="panel-head">
                                <h4 class="panel-title">Applications Trend</h4>
                            </div>
                            <div class="chart-box"><canvas id="applicationsTrendChart"></canvas></div>
                        </div>
                        <div class="panel">
                            <div class="panel-head">
                                <h4 class="panel-title">Hiring Funnel</h4>
                            </div>
                            <div class="chart-box"><canvas id="hiringFunnelChart"></canvas></div>
                        </div>
                        <div class="panel">
                            <h4 class="panel-title mb-3">Recent Alerts</h4>
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex gap-2">
                                    <span class="alert-dot bg-danger"></span>
                                    <div>
                                        <p class="mb-0 small fw-semibold">Interview re-schedule required</p>
                                        <small class="text-muted">Sarah Connor - Senior UX Designer</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <span class="alert-dot bg-success"></span>
                                    <div>
                                        <p class="mb-0 small fw-semibold">Offer accepted</p>
                                        <small class="text-muted">Marcus Wright - Backend Engineer</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-8">
                    <div class="panel p-0 overflow-hidden h-100 d-flex flex-column">
                        <div class="panel-head px-3 pt-3">
