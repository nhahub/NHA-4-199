                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <img class="avatar-sm rounded-circle" alt="Kate" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBlhZxD57y5ve0lQNMkdosoDPH1kZy6yvg7GBZk-pEbAjffd9njrUtjmy7db7QSjfQI81tc99eXftaEat4cUboZ7cXPh49GzT4x-OnkuJ3HQGz6eqrfLBEbZdlMCwnVuiT7peicvKn3g2NTZlud6s2MFI1LUFDaRbdXSlr7WipRGkaA75UGtefiTBb72SqOoyQ_wk2elyWQ5BIMUBTqYqyRzCPmQ5_srGKAy8zmSRrOFDQJ_HR3qmKi"/>
