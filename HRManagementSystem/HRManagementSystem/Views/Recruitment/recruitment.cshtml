                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <img class="avatar-sm rounded-circle" alt="Chloe" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCVfFrMe0w0DPMGtoQ5qXIVZdXsXVgR2rsob8oiG7gmFLA4vN9lwoIu1xltwouIbR4BnfURXzxGfay67JMQj1LzgElGk14YzI4qtQsDAq56foF_IpEDvWQoOSlwxUyLgRK3Cwr3JNGRH8REvDFTge-wmftA-N-XpNWe6bfbE6xd5trp91GGJSeqgOgqkKNcvO-1fybseC4uKBBcrW4HNS6AC-gJm_BGCmkysoO34ajxfTzoq-T0hwes"/>
