                                            <p class="mb-0 small fw-bold">Jack Shephard</p>
                                            <small class="text-muted">System Architect</small>
                                        </div>
                                    </div>
                                    <div class="pt-2 border-top d-flex align-items-center gap-2" style="color:var(--primary)">
                                        <span class="material-symbols-outlined" style="font-size:14px">videocam</span>
