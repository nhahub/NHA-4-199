                                    <span class="material-symbols-outlined" style="font-size:18px; color:var(--success)">check_circle</span>
                                </div>
                                <div class="kanban-card" style="opacity:.6; cursor:not-allowed">
                                    <div class="d-flex align-items-center gap-2">
                                        <img class="avatar-sm rounded-circle" alt="Sawyer" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAkE5x2OYAK_iMlmIYGw2nDvJ7zzPrSMps00qZp968xdpycSowM1P8ZyFdWGf1F1hdQvDUBWmNnOK89w-nO1kPzpRCUyHx_YLJhjLUxTcR7g-vnFayH_QbM-g6JSIp3xrBk8QHk8zt-cpsYGPuaU0bbmFzqbc_bSGo614bn9NrIsukoEh5VivM5dIifs6BFBsVISu_ckBEBFgCL_5PMCW4pg-lwXMv5crScYmB7vV45xOBIghYcmg0B"/>
                                        <div>
                                            <p class="mb-0 small fw-bold">Sawyer Ford</p>
                                            <small class="text-muted">Data Analyst</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
      </div>
    </div>
    @section Scripts
{
    <script src="~/js/recruitment/recruitment-app.js"></script>
}