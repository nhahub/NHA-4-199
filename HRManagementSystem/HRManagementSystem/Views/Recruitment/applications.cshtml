@{
    ViewData["Title"] = "Applications";
}
<div class="app">
      <aside class="sidebar" id="sidebar"></aside>

      <div class="main">
        <header class="topbar" id="topbar"></header>

        <div class="content">
          <div class="subnav-wrap">
            <nav class="nav custom-nav-tabs">
              <a class="nav-link" href="recruitment.html">Overview</a>
              <a class="nav-link" href="requisitions.html">Requisitions</a>
              <a class="nav-link active-tab" href="applications.html">Applications</a>
              <a class="nav-link" href="interviews.html">Interviews</a>
              <a class="nav-link" href="hiring-decision.html">Hiring Decisions</a>
            </nav>
          </div>

          <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
            <div>
              <h1 style="font-size: 24px; font-weight: 700; color: var(--text)">Candidate Applications</h1>
              <div class="panel-sub">Review and manage recruitment candidates.</div>
            </div>
          </div>

          <div class="panel mb-4 p-3">
            <div class="filter-toolbar">
              <div class="search mb-0 flex-grow-1" style="min-width: 220px">
                <span class="material-symbols-outlined">search</span>
                <input id="appSearch" type="text" placeholder="Search candidate..." style="width: 100%" />
              </div>
              <select id="appPosition" class="form-select form-select-sm w-auto">
                <option value="">Position</option>
                <option>Senior Full Stack Developer</option>
                <option>DevOps Engineer</option>
                <option>Enterprise Account Executive</option>
                <option>Product Designer</option>
                <option>QA Specialist</option>
              </select>
              <select id="appStage" class="form-select form-select-sm w-auto">
                <option value="">Stage</option>
                <option>Applied</option>
                <option>Screening</option>
                <option>Interview</option>
                <option>Offer</option>
                <option>Hired</option>
                <option>Rejected</option>
              </select>
              <input id="appDate" type="date" class="form-control form-control-sm w-auto" title="Applied date" />
              <select id="appRating" class="form-select form-select-sm w-auto">
                <option value="0">Rating</option>
                <option value="4">4+ stars</option>
                <option value="3">3+ stars</option>
                <option value="2">2+ stars</option>
              </select>
              <button id="appClear" class="btn btn-link btn-sm text-decoration-none">Clear</button>
            </div>
          </div>

          <div class="panel p-0 overflow-hidden">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">Candidate</th>
                    <th><span class="sortable" data-sort="position">Position <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th>Department</th>
                    <th>Stage</th>
                    <th><span class="sortable" data-sort="applied">Applied <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th><span class="sortable" data-sort="rating">Rating <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody id="appBody"></tbody>
              </table>
            </div>
            <div class="table-footer">
              <span id="appPaginationInfo" class="text-muted small fw-medium">Showing 0 of 0 candidates</span>
              <div class="d-flex gap-1">
                <button class="icon-btn p-1" disabled>
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_left</span>
                </button>
                <button class="btn btn-primary btn-sm px-2 py-1" style="font-size: 12px">1</button>
                <button class="btn btn-light btn-sm px-2 py-1 border text-secondary" style="font-size: 12px">2</button>
                <button class="btn btn-light btn-sm px-2 py-1 border text-secondary" style="font-size: 12px">3</button>
                <button class="icon-btn p-1">
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_right</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    @section Scripts
{
    <script src="~/js/recruitment/applications-app.js"></script>
}