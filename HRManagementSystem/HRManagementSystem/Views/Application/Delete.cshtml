@model HRManagementSystem.BLL.DTOs.ApplicationDto

@{
    ViewData["Title"] = "Delete Application";
}

<div class="container mt-4">

    <div class="card border-danger shadow">

        <div class="card-header bg-danger text-white">
            <h3>Delete Application</h3>
        </div>

        <div class="card-body">

            <h5 class="text-danger mb-4">
                Are you sure you want to delete this application?
            </h5>

            <dl class="row">

                <dt class="col-sm-3">Candidate</dt>
                <dd class="col-sm-9">@Model.CandidateName</dd>

                <dt class="col-sm-3">Job</dt>
                <dd class="col-sm-9">@Model.JobTitle</dd>

                <dt class="col-sm-3">Date</dt>
                <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Stage</dt>
                <dd class="col-sm-9">@Model.Stage</dd>

            </dl>

            <form asp-action="Delete" method="post">

                <input type="hidden" asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger">
                    Delete
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>
