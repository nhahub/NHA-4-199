@model HRManagementSystem.ViewModels.Application.CreateApplicationViewModel

@{
    ViewData["Title"] = "Create Application";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h3>Create Application</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CandidateID" class="form-label"></label>

                    <select asp-for="CandidateID"
                            asp-items="Model.Candidates"
                            class="form-select">
                        <option value="">-- Select Candidate --</option>
                    </select>

                    <span asp-validation-for="CandidateID" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RequisitionID" class="form-label"></label>

                    <select asp-for="RequisitionID"
                            asp-items="Model.Requisitions"
                            class="form-select">
                        <option value="">-- Select Job Requisition --</option>
                    </select>

                    <span asp-validation-for="RequisitionID" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">
                    Save
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
