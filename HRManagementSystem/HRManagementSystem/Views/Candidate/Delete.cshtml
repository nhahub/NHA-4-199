@model HRManagementSystem.BLL.DTOs.CandidateDto

@{
    ViewData["Title"] = "Delete Candidate";
}

<div class="container mt-4">

    <div class="card border-danger shadow">

        <div class="card-header bg-danger text-white">
            <h3>Delete Candidate</h3>
        </div>

        <div class="card-body">

            <h5 class="text-danger">
                Are you sure you want to delete this candidate?
            </h5>

            <hr />

            <dl class="row">

                <dt class="col-sm-3">Person ID</dt>
                <dd class="col-sm-9">@Model.PersonId</dd>

                <dt class="col-sm-3">Resume</dt>
                <dd class="col-sm-9">@Model.ResumeLink</dd>

                <dt class="col-sm-3">Job Requisition</dt>
                <dd class="col-sm-9">@Model.JobRequisition</dd>

            </dl>

            <form asp-action="Delete">

                <input asp-for="Id" type="hidden" />

                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>