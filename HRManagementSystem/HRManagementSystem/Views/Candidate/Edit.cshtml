@model HRManagementSystem.ViewModels.Candidate.UpdateCandidateViewModel

@{
    ViewData["Title"] = "Edit Candidate";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h3>Edit Candidate</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">

                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3"></div>

                <div class="mb-3">

                    <label asp-for="PersonId" class="form-label"></label>

                    <input asp-for="PersonId"
                           class="form-control" />

                    <span asp-validation-for="PersonId"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="ResumeLink" class="form-label"></label>

                    <input asp-for="ResumeLink"
                           class="form-control" />

                    <span asp-validation-for="ResumeLink"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="JobRequisition" class="form-label"></label>

                    <input asp-for="JobRequisition"
                           class="form-control" />

                    <span asp-validation-for="JobRequisition"
                          class="text-danger"></span>

                </div>

                <button type="submit" class="btn btn-primary">
                    Update
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}