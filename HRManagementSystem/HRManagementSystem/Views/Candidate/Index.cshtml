@model IEnumerable<HRManagementSystem.BLL.DTOs.CandidateDto>

@{
    ViewData["Title"] = "Candidates";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Candidates</h2>

        <a asp-action="Create" class="btn btn-success">
            Add Candidate
        </a>
    </div>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Person ID</th>
                <th>Resume</th>
                <th>Job Requisition</th>
                <th width="220">Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var candidate in Model)
            {
                <tr>

                    <td>@candidate.Id</td>
                    <td>@candidate.PersonId</td>
                    <td>@candidate.ResumeLink</td>
                    <td>@candidate.JobRequisition</td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@candidate.Id"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@candidate.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@candidate.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
