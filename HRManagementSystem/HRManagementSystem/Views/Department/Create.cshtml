@model HRManagementSystem.ViewModels.Department.CreateDepartmentViewModel

@{
    ViewData["Title"] = "Create Department";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header">
            <h3>Create Department</h3>
        </div>

        <div class="card-body">

            <form asp-action="Create" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">

                    <label asp-for="Name" class="form-label"></label>

                    <input asp-for="Name" class="form-control" />

                    <span asp-validation-for="Name" class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="Description" class="form-label"></label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="4"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="ManagerId" class="form-label"></label>

                    <select asp-for="ManagerId"
                            asp-items="Model.Managers"
                            class="form-select">

                        <option value="">-- Select Manager --</option>

                    </select>

                    <span asp-validation-for="ManagerId"
                          class="text-danger"></span>

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    Save

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Back

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}