@{
    ViewData["Title"] = "Attendance Records";
}
<div class="app">
      <aside class="sidebar" id="sidebar"></aside>

      <div class="main">
        <header class="topbar" id="topbar"></header>

        <div class="content">
          <div class="subnav-wrap">
            <nav class="nav custom-nav-tabs">
              <a class="nav-link active-tab" href="attendance-records.html">Records</a>
              <a class="nav-link" href="my-attendance.html">My Attendance</a>
            </nav>
          </div>

          <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
            <div>
              <h1 style="font-size: 24px; font-weight: 700; color: var(--text)">Attendance Records</h1>
              <div class="panel-sub">Review employee attendance history.</div>
            </div>
            <button id="exportBtn" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1">
              <span class="material-symbols-outlined" style="font-size: 18px">download</span>Export
            </button>
          </div>

          <div class="panel mb-4 p-3">
            <div class="filter-toolbar">
              <div class="search mb-0 flex-grow-1" style="min-width: 220px">
                <span class="material-symbols-outlined">search</span>
                <input id="recSearch" type="text" placeholder="Search employee..." style="width: 100%" />
              </div>
              <select id="recDept" class="form-select form-select-sm w-auto">
                <option value="">Department</option>
                <option>Engineering</option>
                <option>Marketing</option>
                <option>Sales</option>
                <option>Finance</option>
                <option>HR & Ops</option>
                <option>Product Design</option>
              </select>
              <div class="date-range-pair">
                <input id="recDateFrom" type="date" class="form-control form-control-sm w-auto" title="From" />
                <span class="text-muted small">to</span>
                <input id="recDateTo" type="date" class="form-control form-control-sm w-auto" title="To" />
              </div>
              <select id="recStatus" class="form-select form-select-sm w-auto">
                <option value="">Status</option>
                <option>On Time</option>
                <option>Late</option>
                <option>Absent</option>
                <option>On Leave</option>
                <option>Half Day</option>
              </select>
              <button id="recClear" class="btn btn-link btn-sm text-decoration-none">Clear</button>
            </div>
          </div>

          <div class="panel p-0 overflow-hidden">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">Employee</th>
                    <th>Department</th>
                    <th><span class="sortable" data-sort="date">Date <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th>Shift</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th><span class="sortable" data-sort="hours">Working Hours <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th>Attendance Status</th>
                    <th>Source</th>
                    <th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody id="recBody"></tbody>
              </table>
            </div>
            <div class="table-footer">
              <span id="recPaginationInfo" class="text-muted small fw-medium">Showing 0 of 0 records</span>
              <div class="d-flex gap-1">
                <button class="icon-btn p-1" disabled>
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_left</span>
                </button>
                <button class="btn btn-primary btn-sm px-2 py-1" style="font-size: 12px">1</button>
                <button class="btn btn-light btn-sm px-2 py-1 border text-secondary" style="font-size: 12px">2</button>
                <button class="btn btn-light btn-sm px-2 py-1 border text-secondary" style="font-size: 12px">3</button>
                <button class="icon-btn p-1">
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_right</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    @section Scripts
{
    <script src="~/js/attendance/attendance-records-app.js"></script>
}