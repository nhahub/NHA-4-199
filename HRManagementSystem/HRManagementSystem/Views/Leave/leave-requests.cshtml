@{
    ViewData["Title"] = "Leave Requests";
}
<div class="app">
      <aside class="sidebar" id="sidebar"></aside>

      <div class="main">
        <header class="topbar" id="topbar"></header>

        <div class="content">
          <div class="subnav-wrap">
            <nav class="nav custom-nav-tabs">
              <a class="nav-link" href="leave.html">Overview</a>
              <a class="nav-link active-tab" href="leave-requests.html">Requests</a>
              <a class="nav-link" href="leave-create.html">Request Leave</a>
            </nav>
          </div>

          <div class="mb-4">
            <h1 style="font-size: 24px; font-weight: 700; color: var(--text)">Leave Requests</h1>
            <div class="panel-sub">Review submissions and record the approval decision.</div>
          </div>

          <div class="panel mb-4 p-3">
            <div class="filter-toolbar">
              <div class="search mb-0 flex-grow-1" style="min-width: 220px">
                <span class="material-symbols-outlined">search</span>
                <input id="lrSearch" type="text" placeholder="Search employee..." style="width: 100%" />
              </div>
              <select id="lrType" class="form-select form-select-sm w-auto">
                <option value="">Leave Type</option>
                <option>Annual</option>
                <option>Sick</option>
                <option>Casual</option>
                <option>Unpaid</option>
                <option>Parental</option>
              </select>
              <select id="lrStatus" class="form-select form-select-sm w-auto">
                <option value="">Status</option>
                <option>Pending</option>
                <option>Approved</option>
                <option>Rejected</option>
              </select>
              <div class="date-range-pair">
                <input id="lrDateFrom" type="date" class="form-control form-control-sm w-auto" title="From" />
                <span class="text-muted small">to</span>
                <input id="lrDateTo" type="date" class="form-control form-control-sm w-auto" title="To" />
              </div>
              <button id="lrClear" class="btn btn-link btn-sm text-decoration-none">Clear</button>
            </div>
          </div>

          <div class="panel p-0 overflow-hidden">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">Employee</th>
                    <th>Department</th>
                    <th>Leave Type</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Days</th>
                    <th>Manager Decision</th>
                    <th>Final Status</th>
                    <th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody id="lrBody"></tbody>
              </table>
            </div>
            <div class="table-footer">
              <span id="lrPaginationInfo" class="text-muted small fw-medium">Showing 0 of 0 requests</span>
              <div class="d-flex gap-1">
                <button class="icon-btn p-1" disabled>
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_left</span>
                </button>
                <button class="btn btn-primary btn-sm px-2 py-1" style="font-size: 12px">1</button>
                <button class="btn btn-light btn-sm px-2 py-1 border text-secondary" style="font-size: 12px">2</button>
                <button class="icon-btn p-1">
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_right</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Decision confirmation modal -->
    <div class="modal fade" id="decisionModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="decisionModalTitle">Confirm decision</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="mb-3" id="decisionModalBody">Approve this leave request?</p>
            <label class="text-muted small mb-1 d-block">Note (optional)</label>
            <textarea id="decisionNote" class="form-control" rows="3" placeholder="Add a note for the employee..."></textarea>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="decisionConfirmBtn" class="btn btn-primary btn-sm">Confirm</button>
          </div>
        </div>
      </div>
    </div>
    @section Scripts
{
    <script src="~/js/leave/leave-requests-app.js"></script>
}