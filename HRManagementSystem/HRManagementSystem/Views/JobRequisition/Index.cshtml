@model IEnumerable<HRManagementSystem.BLL.DTOs.JobRequisitionDto>

@{
    ViewData["Title"] = "Job Requisitions";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Job Requisitions</h2>

        <a asp-action="Create" class="btn btn-success">
            Add Job Requisition
        </a>
    </div>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Headcount</th>
                <th>Status</th>
                <th>Department</th>
                <th width="220">Actions</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var job in Model)
            {
                <tr>

                    <td>@job.Id</td>
                    <td>@job.Title</td>
                    <td>@job.Headcount</td>
                    <td>@job.Status</td>
                    <td>@job.DepartmentID</td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@job.Id"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@job.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@job.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>
