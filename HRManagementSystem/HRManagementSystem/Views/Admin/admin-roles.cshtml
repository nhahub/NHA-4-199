@{
ViewData["Title"] = "Roles";
}
<div class="app">
      <aside class="sidebar" id="sidebar"></aside>

      <div class="main">
        <header class="topbar" id="topbar"></header>

        <div class="content">
          <div class="subnav-wrap">
            <nav class="nav custom-nav-tabs">
              <a class="nav-link" href="admin-users.html">Users</a>
              <a class="nav-link active-tab" href="admin-roles.html">Roles &amp; Permissions</a>
              <a class="nav-link" href="admin-shifts.html">Work Shifts</a>
              <a class="nav-link" href="admin-settings.html">Settings</a>
            </nav>
          </div>

          <div class="mb-4">
            <h1 style="font-size: 24px; font-weight: 700; color: var(--text)">Roles &amp; Permissions</h1>
            <div class="panel-sub">Control what each role can view, create, edit and delete across the system.</div>
          </div>

          <div class="row g-3">
            <div class="col-12 col-lg-3">
              <div class="panel">
                <h4 class="panel-title mb-3">Roles</h4>
                <div class="role-list" id="roleList"></div>
              </div>
            </div>

            <div class="col-12 col-lg-9">
              <div class="panel">
                <div class="panel-head">
                  <div>
                    <h4 class="panel-title mb-0" id="matrixRoleName">Admin</h4>
                    <div class="panel-sub">Module-level access for this role</div>
                  </div>
                  <span id="matrixRoleUsers" class="text-muted small">12 users assigned</span>
                </div>

                <div class="table-responsive">
                  <table class="table align-middle mb-0 perm-table">
                    <thead>
                      <tr>
                        <th class="ps-2">Module</th>
                        <th>View</th>
                        <th>Create</th>
                        <th>Edit</th>
                        <th class="pe-2">Delete</th>
                      </tr>
                    </thead>
                    <tbody id="permBody"></tbody>
                  </table>
                </div>

                <div class="d-flex justify-content-end mt-4 gap-2">
                  <button class="btn btn-outline-secondary btn-sm" id="resetPermBtn">Reset</button>
                  <button class="btn btn-primary btn-sm" id="savePermBtn">Save Changes</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
@section Scripts
{
<script src="~/js/admin/admin-roles-app.js"></script>
}