@{ViewData["Title"] = "Users";}

<div class="app">
      <aside class="sidebar" id="sidebar"></aside>

      <div class="main">
        <header class="topbar" id="topbar"></header>

        <div class="content">
          <div class="subnav-wrap">
            <nav class="nav custom-nav-tabs">
              <a class="nav-link active-tab" href="admin-users.html">Users</a>
              <a class="nav-link" href="admin-roles.html">Roles &amp; Permissions</a>
              <a class="nav-link" href="admin-shifts.html">Work Shifts</a>
              <a class="nav-link" href="admin-settings.html">Settings</a>
            </nav>
          </div>

          <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
            <div>
              <h1 style="font-size: 24px; font-weight: 700; color: var(--text)">Users Management</h1>
              <div class="panel-sub">Manage system accounts and access.</div>
            </div>
            <button id="createUserBtn" class="btn btn-primary btn-sm d-flex align-items-center gap-1">
              <span class="material-symbols-outlined" style="font-size: 18px">person_add</span>Create User
            </button>
          </div>

          <div class="panel mb-4 p-3">
            <div class="filter-toolbar">
              <div class="search mb-0 flex-grow-1" style="min-width: 220px">
                <span class="material-symbols-outlined">search</span>
                <input id="userSearch" type="text" placeholder="Search name or email..." style="width: 100%" />
              </div>
              <select id="userRole" class="form-select form-select-sm w-auto">
                <option value="">Role</option>
                <option>Admin</option>
                <option>HR Manager</option>
                <option>Payroll Admin</option>
                <option>Hiring Manager</option>
                <option>Employee</option>
              </select>
              <select id="userStatus" class="form-select form-select-sm w-auto">
                <option value="">Status</option>
                <option>Active</option>
                <option>Disabled</option>
                <option>Invited</option>
              </select>
              <button id="userClear" class="btn btn-link btn-sm text-decoration-none">Clear</button>
            </div>
          </div>

          <div class="panel p-0 overflow-hidden">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead>
                  <tr>
                    <th class="ps-4">User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Linked Employee</th>
                    <th><span class="sortable" data-sort="status">Status <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th><span class="sortable" data-sort="lastLoginSort">Last Login <span class="material-symbols-outlined">unfold_more</span></span></th>
                    <th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody id="userBody"></tbody>
              </table>
            </div>
            <div class="table-footer">
              <span id="userPaginationInfo" class="text-muted small fw-medium">Showing 0 of 0 users</span>
              <div class="d-flex gap-1">
                <button class="icon-btn p-1" disabled>
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_left</span>
                </button>
                <button class="btn btn-primary btn-sm px-2 py-1" style="font-size: 12px">1</button>
                <button class="btn btn-light btn-sm px-2 py-1 border text-secondary" style="font-size: 12px">2</button>
                <button class="icon-btn p-1">
                  <span class="material-symbols-outlined" style="font-size: 18px">chevron_right</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Confirmation modal (disable / reset password) -->
    <div class="modal fade" id="userConfirmModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="userConfirmTitle">Confirm action</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="mb-0" id="userConfirmBody">Are you sure?</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="userConfirmBtn" class="btn btn-danger btn-sm">Confirm</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Create user modal -->
    <div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Create User</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label small fw-semibold">Full Name</label>
              <input type="text" class="form-control" placeholder="e.g. Jamie Rivera" />
            </div>
            <div class="mb-3">
              <label class="form-label small fw-semibold">Email</label>
              <input type="email" class="form-control" placeholder="jamie.rivera@enterprise.com" />
            </div>
            <div class="row g-3">
              <div class="col-6">
                <label class="form-label small fw-semibold">Role</label>
                <select class="form-select">
                  <option>Admin</option>
                  <option>HR Manager</option>
                  <option>Payroll Admin</option>
                  <option>Hiring Manager</option>
                  <option selected>Employee</option>
                </select>
              </div>
              <div class="col-6">
                <label class="form-label small fw-semibold">Linked Employee</label>
                <select class="form-select">
                  <option value="">None</option>
                  <option>Robert Fox</option>
                  <option>Jane Cooper</option>
                  <option>Leslie Alexander</option>
                </select>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="button" id="createUserConfirmBtn" class="btn btn-primary btn-sm">Send Invite</button>
          </div>
        </div>
      </div>
    </div>
@section Scripts
{
    <script src="~/js/admin/admin-users-app.js"></script>
}