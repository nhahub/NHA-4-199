@using HRManagementSystem.Web.ViewModels.HRManagementSystem.PL.ViewModels
@model RegisterViewModel
@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="ar" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR Management System - Register</title>
    <link rel="stylesheet" href="~/css/auth-style.css" />
</head>
<body>

    <div class="auth-container">
        <div class="auth-card">
            <h2>Create Account  </h2>

            <form asp-action="Register" asp-controller="Account" method="post">
                <div asp-validation-summary="All" class="validation-message"></div>

                <div class="input-group">
                    <input asp-for="UserName" placeholder="Username" />
                    <span asp-validation-for="UserName" class="validation-message"></span>
                </div>

                <div class="input-group">
                    <input asp-for="Email" placeholder="Email Address" />
                    <span asp-validation-for="Email" class="validation-message"></span>
                </div>

                <div class="input-group">
                    <input asp-for="Password" placeholder="Password" />
                    <span asp-validation-for="Password" class="validation-message"></span>
                </div>

                <div class="input-group">
                    <input asp-for="ConfirmPassword" placeholder="Confirm Password" />
                    <span asp-validation-for="ConfirmPassword" class="validation-message"></span>
                </div>

                <button type="submit" class="btn-primary">Register</button>
            </form>

            <p class="toggle-text">Already have an account? <a href="/Account/Login">Login here</a></p>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>